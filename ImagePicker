_G.ImagePicker = {}
local Picker = _G.ImagePicker

Picker.RootFolder = ""
Picker.Selected = nil
Picker.OnChoose = nil

local BATCH_SIZE = 5
local SCAN_CHUNK = 200

local function isImage(path)
    local ext = path:lower():match("%.([%w]+)$")
    return ext and (ext == "png" or ext == "jpg" or ext == "jpeg" or ext == "webp")
end

local function scanFolderAsync(startFolder, onFile, onDone)
    task.spawn(function()
        local stack = { startFolder }
        while #stack > 0 do
            local folder = table.remove(stack)
            if isfolder(folder) then
                local files = listfiles(folder)
                local counter = 0
                for _, f in ipairs(files) do
                    if isfolder(f) then
                        table.insert(stack, f)
                    else
                        if isImage(f) then
                            onFile(f)
                        end
                    end
                    counter += 1
                    if counter >= SCAN_CHUNK then
                        counter = 0
                        task.wait()
                    end
                end
            end
        end
        onDone()
    end)
end

local function formatPath(file)
    local path = file:gsub("\\", "/")
    if Picker.RootFolder and Picker.RootFolder ~= "" then
        local root = Picker.RootFolder:gsub("\\", "/")
        path = path:gsub("^" .. root .. "/?", "")
    end
    return path
end

