local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService")

local M = {}

local ROOT_NAME = "NotifyRoot"
pcall(function()
	local old = CoreGui:FindFirstChild(ROOT_NAME)
	if old then
		old:Destroy()
	end
end)

local root = Instance.new("ScreenGui")
root.Name = ROOT_NAME
root.ResetOnSpawn = false
root.IgnoreGuiInset = true
root.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
root.Parent = CoreGui

local icons = {
	info = "rbxassetid://17829948066",
	warning = "rbxassetid://139354174011123",
	error = "rbxassetid://126771886058617"
}

local styles = {
	info = {
		accent = Color3.fromRGB(85, 160, 255),
		title = "Info"
	},
	warning = {
		accent = Color3.fromRGB(255, 183, 77),
		title = "Warning"
	},
	error = {
		accent = Color3.fromRGB(255, 96, 96),
		title = "Error"
	}
}

local stack = {}

local function tween(obj, time, props, style, direction)
	local ti = TweenInfo.new(
		time,
		style or Enum.EasingStyle.Quart,
		direction or Enum.EasingDirection.Out
	)
	local tw = TweenService:Create(obj, ti, props)
	tw:Play()
	return tw
end

local function removeFromStack(target)
	for i = #stack, 1, -1 do
		if stack[i] == target then
			table.remove(stack, i)
			return
		end
	end
end

local function reflow()
	for i, n in ipairs(stack) do
		if n and n.gui and n.gui.Parent and not n.closing then
			local scaleTarget = math.max(0.84, 1 - ((i - 1) * 0.055))
			local yOffset = (i - 1) * 58

			tween(n.scale, 0.24, { Scale = scaleTarget })
			tween(n.holder, 0.24, {
				Position = UDim2.new(0.5, 0, 0.5, yOffset)
			})
		end
	end
end

function M.notify(ntype, msg)
	local kind = tostring(ntype or "info"):lower()
	local meta = styles[kind] or styles.info
	local iconId = icons[kind] or icons.info

	local gui = Instance.new("Frame")
	gui.Name = "Notify_" .. HttpService:GenerateGUID(false)
	gui.BackgroundTransparency = 1
	gui.Size = UDim2.fromScale(1, 1)
	gui.Parent = root

	local holder = Instance.new("Frame")
	holder.Name = "Holder"
	holder.AnchorPoint = Vector2.new(0.5, 0.5)
	holder.Position = UDim2.new(0.5, 0, 0.5, 0)
	holder.Size = UDim2.fromOffset(460, 184)
	holder.BackgroundTransparency = 1
	holder.BorderSizePixel = 0
	holder.Parent = gui

	local scale = Instance.new("UIScale")
	scale.Scale = 0.92
	scale.Parent = holder

	local shadow = Instance.new("ImageLabel")
	shadow.Name = "Shadow"
	shadow.BackgroundTransparency = 1
	shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	shadow.Position = UDim2.fromScale(0.5, 0.5)
	shadow.Size = UDim2.new(1, 44, 1, 44)
	shadow.Image = "rbxassetid://1316045217"
	shadow.ImageTransparency = 1
	shadow.ScaleType = Enum.ScaleType.Slice
	shadow.SliceCenter = Rect.new(10, 10, 118, 118)
	shadow.ZIndex = 0
	shadow.Parent = holder

	local card = Instance.new("Frame")
	card.Name = "Card"
	card.Size = UDim2.fromScale(1, 1)
	card.BackgroundColor3 = Color3.fromRGB(28, 28, 33)
	card.BackgroundTransparency = 1
	card.BorderSizePixel = 0
	card.ClipsDescendants = true
	card.Parent = holder

	local cardCorner = Instance.new("UICorner")
	cardCorner.CornerRadius = UDim.new(0, 18)
	cardCorner.Parent = card

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(255, 255, 255)
	stroke.Transparency = 1
	stroke.Thickness = 1
	stroke.Parent = card

	local gradient = Instance.new("UIGradient")
	gradient.Rotation = 90
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(34, 34, 40)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(24, 24, 28))
	})
	gradient.Parent = card

	local accentBar = Instance.new("Frame")
	accentBar.Name = "AccentBar"
	accentBar.Size = UDim2.new(1, 0, 0, 4)
	accentBar.BackgroundColor3 = meta.accent
	accentBar.BackgroundTransparency = 1
	accentBar.BorderSizePixel = 0
	accentBar.Parent = card

	local iconBg = Instance.new("Frame")
	iconBg.Name = "IconBg"
	iconBg.Position = UDim2.fromOffset(20, 22)
	iconBg.Size = UDim2.fromOffset(52, 52)
	iconBg.BackgroundColor3 = meta.accent
	iconBg.BackgroundTransparency = 1
	iconBg.BorderSizePixel = 0
	iconBg.Parent = card

	local iconBgCorner = Instance.new("UICorner")
	iconBgCorner.CornerRadius = UDim.new(1, 0)
	iconBgCorner.Parent = iconBg

	local iconBgStroke = Instance.new("UIStroke")
	iconBgStroke.Color = meta.accent
	iconBgStroke.Transparency = 1
	iconBgStroke.Thickness = 1
	iconBgStroke.Parent = iconBg

	local icon = Instance.new("ImageLabel")
	icon.Name = "Icon"
	icon.BackgroundTransparency = 1
	icon.Size = UDim2.fromOffset(26, 26)
	icon.Position = UDim2.fromOffset(13, 13)
	icon.Image = iconId
	icon.ImageTransparency = 1
	icon.Parent = iconBg

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Position = UDim2.fromOffset(84, 22)
	title.Size = UDim2.new(1, -110, 0, 24)
	title.Font = Enum.Font.GothamSemibold
	title.Text = meta.title
	title.TextSize = 18
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextTransparency = 1
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = card

	local message = Instance.new("TextLabel")
	message.BackgroundTransparency = 1
	message.Position = UDim2.fromOffset(84, 50)
	message.Size = UDim2.new(1, -108, 0, 78)
	message.Font = Enum.Font.Gotham
	message.Text = tostring(msg or "")
	message.TextSize = 16
	message.TextColor3 = Color3.fromRGB(230, 230, 230)
	message.TextTransparency = 1
	message.TextWrapped = true
	message.TextXAlignment = Enum.TextXAlignment.Left
	message.TextYAlignment = Enum.TextYAlignment.Top
	message.Parent = card

	local ok = Instance.new("TextButton")
	ok.Name = "Ok"
	ok.AnchorPoint = Vector2.new(0.5, 1)
	ok.Position = UDim2.new(0.5, 0, 1, -16)
	ok.Size = UDim2.fromOffset(116, 36)
	ok.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	ok.BackgroundTransparency = 1
	ok.BorderSizePixel = 0
	ok.Text = "Ok"
	ok.Font = Enum.Font.GothamSemibold
	ok.TextSize = 15
	ok.TextColor3 = Color3.fromRGB(255, 255, 255)
	ok.TextTransparency = 1
	ok.AutoButtonColor = false
	ok.Parent = card

	local okCorner = Instance.new("UICorner")
	okCorner.CornerRadius = UDim.new(0, 10)
	okCorner.Parent = ok

	local okStroke = Instance.new("UIStroke")
	okStroke.Color = Color3.fromRGB(255, 255, 255)
	okStroke.Transparency = 1
	okStroke.Thickness = 1
	okStroke.Parent = ok

	local notify = {
		gui = gui,
		holder = holder,
		scale = scale,
		closing = false
	}

	table.insert(stack, 1, notify)
	reflow()

	local function closeNotify()
		if notify.closing then
			return
		end
		notify.closing = true

		removeFromStack(notify)
		reflow()

		tween(scale, 0.18, { Scale = 0.9 })
		tween(shadow, 0.18, { ImageTransparency = 1 })
		tween(card, 0.18, { BackgroundTransparency = 1 })
		tween(stroke, 0.18, { Transparency = 1 })
		tween(accentBar, 0.18, { BackgroundTransparency = 1 })
		tween(iconBg, 0.18, { BackgroundTransparency = 1 })
		tween(iconBgStroke, 0.18, { Transparency = 1 })
		tween(icon, 0.18, { ImageTransparency = 1 })
		tween(title, 0.18, { TextTransparency = 1 })
		tween(message, 0.18, { TextTransparency = 1 })
		tween(ok, 0.18, { BackgroundTransparency = 1, TextTransparency = 1 })
		tween(okStroke, 0.18, { Transparency = 1 })

		task.delay(0.2, function()
			if gui and gui.Parent then
				gui:Destroy()
			end
		end)
	end

	ok.MouseButton1Click:Connect(closeNotify)

	tween(shadow, 0.22, { ImageTransparency = 0.45 })
	tween(scale, 0.22, { Scale = 1 }, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
	tween(card, 0.22, { BackgroundTransparency = 0 })
	tween(stroke, 0.22, { Transparency = 0.88 })
	tween(accentBar, 0.22, { BackgroundTransparency = 0 })
	tween(iconBg, 0.22, { BackgroundTransparency = 0.86 })
	tween(iconBgStroke, 0.22, { Transparency = 0.7 })
	tween(icon, 0.22, { ImageTransparency = 0 })
	tween(title, 0.22, { TextTransparency = 0 })
	tween(message, 0.22, { TextTransparency = 0 })
	tween(ok, 0.22, { BackgroundTransparency = 0, TextTransparency = 0 })
	tween(okStroke, 0.22, { Transparency = 0.88 })

	return gui
end

return M
